DIR=$HOME/.dotfiles/scripts

alias t='tmux'
alias g='git'
alias gs='git status'
alias gl='git log'
alias gc='git commit'
alias gd='git diff'
alias l='eza -l --icons --git'
alias la='eza -la --icons --git'
alias lt='eza --long --tree --level=2 --icons --git'
alias ls='ls --color=auto'
alias docker-compose='docker compose'
alias weather='curl wttr.in/:Челябинск'
alias CombineAudio='pactl load-module module-combine-sink'
alias CombineAudioOff='pactl unload-module module-combine-sink'
alias get-extension-id="$DIR/firefox-extract-extension-id.sh"
alias open='xdg-open'
alias hx='helix'
alias vi='nvim'
alias tf='terraform'
alias distrobox-arch='distrobox enter arch'
alias ssh-list="rg '^\s*Host\s+' ~/.ssh/config | awk '{print $2}'"
alias ssh-work-list="rg '^\s*Host\s+' ~/.ssh/config-work | awk '{print $2}'"
alias zapret='sudo systemctl start zapret.service'
alias zapretOff='sudo systemctl stop zapret.service'

alias uphome='sudo systemctl start wg-quick-home'
alias uphome-nolan='sudo systemctl start wg-quick-home-nolan'
alias downvpn='sudo systemctl stop wg-quick-home wg-quick-home-nolan'

if command -v pacman &>/dev/null; then
  alias up="$DIR/update.sh"
fi

